-- ========== DROP TABLES ==========
DROP TABLE IF EXISTS Performance, Queues, Transactions, Employees, CashDesks, Branches CASCADE;

-- ========== CREATE TABLES ==========

-- 1. Branches
CREATE TABLE Branches (
    BranchID INT PRIMARY KEY,
    BranchName VARCHAR(100) NOT NULL,
    Region VARCHAR(50) NOT NULL,
    Address TEXT,
    ManagerID INT
);

-- 2. CashDesks
CREATE TABLE CashDesks (
    CashDeskID INT PRIMARY KEY,
    BranchID INT NOT NULL,
    CashDeskName VARCHAR(50) NOT NULL,
    Status VARCHAR(20) CHECK (Status IN ('Active', 'Inactive')),
    FOREIGN KEY (BranchID) REFERENCES Branches(BranchID)
);

-- 3. Employees
CREATE TABLE Employees (
    EmployeeID INT PRIMARY KEY,
    BranchID INT,
    CashDeskID INT,
    FullName VARCHAR(100) NOT NULL,
    Position VARCHAR(50),
    HireDate DATE CHECK (HireDate <= CURRENT_DATE),
    Salary NUMERIC CHECK (Salary >= 0),
    FOREIGN KEY (BranchID) REFERENCES Branches(BranchID),
    FOREIGN KEY (CashDeskID) REFERENCES CashDesks(CashDeskID)
);

-- 4. Transactions
CREATE TABLE Transactions (
    TransactionID VARCHAR(20) PRIMARY KEY,
    BranchID INT,
    CashdeskID INT,
    EmployeeID INT,
    Date DATE NOT NULL,
    Amount NUMERIC CHECK (Amount >= 0),
    Profit NUMERIC CHECK (Profit >= 0),
    Currency VARCHAR(10) CHECK (Currency IN ('UZS', 'USD', 'EUR', 'RUB')),
    TransferTime TIME,
    FOREIGN KEY (BranchID) REFERENCES Branches(BranchID),
    FOREIGN KEY (CashdeskID) REFERENCES CashDesks(CashDeskID),
    FOREIGN KEY (EmployeeID) REFERENCES Employees(EmployeeID)
);

-- 5. Queues
CREATE TABLE Queues (
    QueueID VARCHAR(20) PRIMARY KEY,
    BranchID INT,
    DateTime TIMESTAMP NOT NULL,
    ClientsInQue INT CHECK (ClientsInQue >= 0),
    AverageWaitTime NUMERIC CHECK (AverageWaitTime >= 0),
    FOREIGN KEY (BranchID) REFERENCES Branches(BranchID)
);

-- 6. Performance
CREATE TABLE Performance (
    TransactionID VARCHAR(20),
    EmployeeID INT,
    Errors VARCHAR(10),
    ProcessTime INT CHECK (ProcessTime >= 0),
    FOREIGN KEY (TransactionID) REFERENCES Transactions(TransactionID),
    FOREIGN KEY (EmployeeID) REFERENCES Employees(EmployeeID)
);

-- ========== CLEANING LOGIC ==========

-- Trim strings
UPDATE Employees SET FullName = TRIM(FullName), Position = TRIM(Position);
UPDATE Branches SET BranchName = TRIM(BranchName), Region = TRIM(Region);
UPDATE CashDesks SET CashDeskName = TRIM(CashDeskName);
UPDATE Transactions SET Currency = UPPER(TRIM(Currency));

-- Nullify empty strings
UPDATE Transactions SET Currency = NULL WHERE Currency = '';

-- ========== ANALYTICAL VIEWS ==========

-- View: Employee Transaction Summary
CREATE OR REPLACE VIEW EmployeeTransactionSummary AS
SELECT
    e.EmployeeID,
    e.FullName,
    COUNT(t.TransactionID) AS NumTransactions,
    ROUND(SUM(t.Amount), 2) AS TotalAmount,
    ROUND(AVG(t.Profit), 2) AS AvgProfit,
    MAX(t.Date) AS LastTransactionDate
FROM Employees e
LEFT JOIN Transactions t ON e.EmployeeID = t.EmployeeID
GROUP BY e.EmployeeID, e.FullName;

-- View: Branch Performance
CREATE OR REPLACE VIEW BranchPerformance AS
SELECT
    b.BranchID,
    b.BranchName,
    COUNT(t.TransactionID) AS TotalTransactions,
    ROUND(SUM(t.Amount), 2) AS Revenue,
    ROUND(AVG(q.AverageWaitTime), 2) AS AvgWait,
    COUNT(DISTINCT e.EmployeeID) AS NumEmployees
FROM Branches b
LEFT JOIN Transactions t ON b.BranchID = t.BranchID
LEFT JOIN Queues q ON b.BranchID = q.BranchID
LEFT JOIN Employees e ON b.BranchID = e.BranchID
GROUP BY b.BranchID, b.BranchName;

-- ========== INDEXES ==========

CREATE INDEX idx_transaction_date ON Transactions(Date);
CREATE INDEX idx_employee_salary ON Employees(Salary);
CREATE INDEX idx_queue_datetime ON Queues(DateTime);

-- ========== STORED PROCEDURE EXAMPLE ==========

-- Procedure to get top N employees by total transaction amount
CREATE OR REPLACE FUNCTION GetTopEmployees(limit_n INT)
RETURNS TABLE (
    EmployeeID INT,
    FullName VARCHAR,
    TotalAmount NUMERIC
) AS $$
BEGIN
    RETURN QUERY
    SELECT e.EmployeeID, e.FullName, SUM(t.Amount) AS TotalAmount
    FROM Employees e
    JOIN Transactions t ON e.EmployeeID = t.EmployeeID
    GROUP BY e.EmployeeID, e.FullName
    ORDER BY TotalAmount DESC
    LIMIT limit_n;
END;
$$ LANGUAGE plpgsql;

-- ========== SAMPLE ANALYST QUERIES ==========

-- Top 5 cash desks by transaction volume
SELECT CashDeskID, COUNT(*) AS Total
FROM Transactions
GROUP BY CashDeskID
ORDER BY Total DESC
LIMIT 5;

-- Employee performance with errors
SELECT p.EmployeeID, e.FullName, COUNT(*) AS ErrorCount
FROM Performance p
JOIN Employees e ON p.EmployeeID = e.EmployeeID
WHERE p.Errors != 'No'
GROUP BY p.EmployeeID, e.FullName
ORDER BY ErrorCount DESC;

-- High waiting times per branch
SELECT BranchID, AVG(AverageWaitTime) AS AvgWait
FROM Queues
GROUP BY BranchID
HAVING AVG(AverageWaitTime) > 20;




